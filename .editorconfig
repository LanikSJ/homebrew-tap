# http://editorconfig.org
root = true

[*]
indent_style = space
indent_size = 2
tab_width = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

[*.rb]
indent_style = space
indent_size = 2
max_line_length = 120

[*.{js,ts,jsx,tsx,json,md}]
indent_style = space
indent_size = 2

[*.yml]
indent_style = space
indent_size = 2

[*.{rake,gemspec,ru}]
indent_style = space
indent_size = 2
max_line_length = 120
